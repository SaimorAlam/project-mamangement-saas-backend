model Submitted {
  id               String             @id @default(uuid())
  information      String
  submission       String
  status           SubmittedStatus    @default(PENDING)
  employee         Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  employeeId       String?
  project          Project            @relation(fields: [projectId], references: [id])
  projectId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  submissionReturn SubmissionReturn?
  elements         SubmittedElement[]
}

model SubmittedElement {
  id String @id @default(uuid())

  chart   ChartTable @relation(fields: [chartId], references: [id])
  chartId String

  xAxis       Json?
  yAxis       Json?
  zAxis       Json?
  submitted   Submitted @relation(fields: [submittedId], references: [id], onDelete: Cascade)
  submittedId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

